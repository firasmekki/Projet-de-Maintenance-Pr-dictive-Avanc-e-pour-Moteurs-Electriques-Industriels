# Application
APP_NAME=ORBIT AI Industrial Copilot
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# PostgreSQL (async driver)
DATABASE_URL=postgresql+asyncpg://orbit:orbit@localhost:5432/orbit_ai
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ML
ML_MODEL_DIR=ml/models
ML_RETRAIN_ON_STARTUP=false
