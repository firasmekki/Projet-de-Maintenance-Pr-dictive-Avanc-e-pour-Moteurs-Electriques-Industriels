APP_NAME="ORBIT AI Industrial Copilot API"
APP_VERSION="0.1.0"
ENVIRONMENT=local
DEBUG=false
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:5173"]
LOG_LEVEL=INFO
LOG_JSON=true

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=orbit
POSTGRES_PASSWORD=orbit
POSTGRES_DB=orbit_ai
DATABASE_URL=postgresql+psycopg://orbit:orbit@postgres:5432/orbit_ai
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
TEST_DATABASE_URL=sqlite+pysqlite:///:memory:

CHROMA_HOST=chromadb
CHROMA_PORT=8000

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b
